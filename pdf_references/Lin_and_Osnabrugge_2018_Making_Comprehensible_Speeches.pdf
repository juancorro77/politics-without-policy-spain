<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script src="/js/jquery-3.7.0.min.js"></script>
    <script src="/js/turbolinks.min.js"></script>

<script>
    jQuery(document).ready(function ($) {

        
        $('html').css('overflow', 'auto');

        var $toggle = $('#nav-toggle');
        var $menu = $('#nav-menu');

        $toggle.click(function() {
            $(this).toggleClass('is-active');
            $menu.toggleClass('is-active');
        });

                            
        $('.tree a').on('mouseover focus', function(e) {
            $.get($(this).attr("href"), function(data, status) {
                if (data.Description) {
                    $('#org_info').show();

                    $('#org_title').text(data.Name);
                    $('#org_desc').text(data.Description);
                } else {
                    $('#org_info').hide();
                }
            });
        });

        $('.navbar-link').focus(function() {
            var link = $(this);
            var dropdown = link.next('.navbar-dropdown');
            dropdown.css('display', 'block');

            dropdown.children().last().on('blur', function() {
                dropdown.attr('style', '');
            });
        });

        $('.navbar-link').blur(function() {
            var link = $(this);
            var dropdown = link.next('.navbar-dropdown');
            var children = dropdown.children();

            // timeout to handle split second of focus loss from tab
            setTimeout(function() {
                if (! children.is(':focus')) {
                    dropdown.attr('style', '');
                }
            }, 10);
        });

        // Check for click events on the navbar burger icon
        $(".navbar-burger").click(function() {

            // Toggle the "is-active" class on both the "navbar-burger" and the "navbar-menu"
            $(".navbar-burger").toggleClass("is-active");
            $(".navbar-menu").toggleClass("is-active");

        });

        $(window).click(function() {
            var dropdowns = $('.navbar-dropdown');
            if (dropdowns.is(':visible')) {
                dropdowns.attr('style', '');
            }
        });

        $(document).keypress(function(event){
            var keycode = (event.keyCode ? event.keyCode : event.which);
            var $modal = $('#search');
            if(keycode == '13' && $modal.hasClass('is-active')){
                $('#advancedform').submit();
                $modal.find('button.is-link').html('Searching')
                    .attr('disabled', true);
            }
        });

        var checkContainerExist = setInterval(function() {
            if ($('#irus_widget_form').length) {
            $('#badge_only_checkbox').attr('aria-label', 'Badge only')
            $('#badge_legend_checkbox').attr('aria-label', 'Badge legend')
            $('#start_date_selector').attr('aria-label', 'Start date')
            $('#end_date_selector').attr('aria-label', 'End date')
            $('#item_types_checkbox').attr('aria-label', 'Item types')

            clearInterval(checkContainerExist);
            }
        }, 100); // check every 100ms

        const clearConfirm = `CLEARDOWN`
        
        $('#cleardown').on('click', async function() {
            let check = prompt(`Are you sure you want to cleardown? type ${clearConfirm}`); 
            
            if (check === clearConfirm) {
                const url = 'https://durham-repository.worktribe.com/cleardown'
                
                fetch(url)
                    .then((response) => response.json())
                    .then(({ message }) => {
                        alert(message)
                    });
            }
        })

        const syncConfirm = `KITCHENSINK`

        $('#fullsync').on('click', async function() {
            let check = prompt(`Are you sure you want to do a full sync? type ${syncConfirm}`); 
            
            if (check === syncConfirm) {
                $(this).html('Syncing...')

                const url = 'https://durham-repository.worktribe.com/fullsync'
                
                fetch(url)
                    .then((response) => response.json())
                    .then(({ message }) => {
                        $(this).html('Full Sync')

                        alert(message)
                    });
            }
        })
    });
</script>
